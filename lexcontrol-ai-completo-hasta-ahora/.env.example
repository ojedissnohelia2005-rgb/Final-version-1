# LexControl AI local secrets.
# Copy this file to .env.local and fill values there. Do not include .env.local in the final zip.

OPENAI_API_KEY="YOUR_OPENAI_PROJECT_KEY"
OPENAI_SIMPLE_MODEL="gpt-4o-mini"
OPENAI_ANALYSIS_MODEL="gpt-4o"
OPENAI_EMBEDDINGS_MODEL="text-embedding-3-small"

VITE_GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_BROWSER_KEY"
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_BROWSER_KEY"

GOOGLE_OAUTH_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/drive/callback"
DRIVE_ENCRYPTION_KEY="GENERATE_WITH_OPENSSL_RAND_HEX_32"
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL="api-a-drive@your-project.iam.gserviceaccount.com"

CRON_SECRET="GENERATE_A_LONG_RANDOM_SECRET"
APP_URL="http://localhost:3000"
